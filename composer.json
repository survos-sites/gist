{
    "name": "survos-sites/gist",
    "description": "A fast word-by-word translator using freedict dictionaries",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-libxml": "*",
        "ext-xmlreader": "*",
        "api-platform/core": "^4.3.5",
        "api-platform/doctrine-orm": "^4.2.8",
        "api-platform/symfony": "^4.2.8",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/inflector": "^2.1",
        "doctrine/orm": "^3.6.5",
        "easycorp/easyadmin-bundle": "^5.0.8",
        "inspector-apm/inspector-symfony": "^1.11.4",
        "phpdocumentor/reflection-docblock": "^5.6.7|^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "skoro/stardict": "^0.2.1",
        "survos/data-contracts": "^2.4",
        "survos/deployment-bundle": "^2.4.4",
        "survos/field-bundle": "^2.4.4",
        "survos/search-bundle": "^2.4",
        "survos/state-bundle": "^2.4",
        "survos/tabler-bundle": "^2.4.4",
        "survos/tui-extras-bundle": "^2.4",
        "symfony/asset": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/filesystem": "^8.1",
        "symfony/flex": "^2.10",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/intl": "^8.1",
        "symfony/mailer": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/notifier": "^8.1",
        "symfony/process": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-bundle": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/string": "^8.1",
        "symfony/translation": "^8.1",
        "symfony/tui": "^8.1@beta",
        "symfony/twig-bundle": "^8.1",
        "symfony/ux-turbo": "^3.0",
        "symfony/validator": "^8.1",
        "symfony/web-link": "^8.1",
        "symfony/yaml": "^8.1",
        "twig/extra-bundle": "^3.24.0",
        "twig/string-extra": "^3.24.0",
        "twig/twig": "^3.26.0",
        "wamania/php-stemmer": ">=4",
        "wapmorgan/unified-archive": "^1.3"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "php -d memory_limit=512M bin/console cache:clear",
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "php -d memory_limit=512M bin/console cache:clear",
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "require-dev": {
        "jawira/doctrine-diagram-bundle": "^1.2",
        "phpunit/phpunit": "^13.1.10",
        "roave/better-reflection": "^6.71",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/debug-bundle": "^8.1",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.1"
    }
}
