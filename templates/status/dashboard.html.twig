{% extends 'base.html.twig' %}

{% block title %}FreeDict Status{% endblock %}

{% block body %}
<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">
              FreeDict Status
              <span class="badge bg-secondary ms-2">{{ pairs|length }} pair{{ pairs|length == 1 ? '' : 's' }}</span>
            </h3>
            <div class="card-actions">
              <a class="btn btn-outline-secondary" href="/">Open Translator</a>
            </div>
          </div>
          <div class="table-responsive">
            <table class="table card-table table-vcenter">
              <thead>
                <tr>
                  <th>Pair</th>
                  <th class="text-nowrap">Release</th>
                  <th class="text-end">Src Lemmas</th>
                  <th class="text-end">Dst Lemmas</th>
                  <th class="text-end">Edges</th>
                  <th>Top 5 Longest (src)</th>
                  <th>Recent (src)</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
              {% for p in pairs %}
                <tr>
                  <td class="text-nowrap">
                    <div class="d-flex align-items-center">
                      <div>
                        <div class="fw-bold">{{ p.name }}</div>
                        <div class="text-muted">
                          <span class="badge bg-blue-lt">{{ p.src }}</span>
                          <span class="badge bg-green-lt">{{ p.dst }}</span>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td class="text-nowrap">
                    {% if p.version %}<span class="badge bg-azure-lt">v{{ p.version }}</span>{% endif %}
                    {% if p.date %}<small class="text-muted ms-1">{{ p.date }}</small>{% endif %}
                  </td>
                  <td class="text-end">{{ p.counts.src_lemmas|number_format }}</td>
                  <td class="text-end">{{ p.counts.dst_lemmas|number_format }}</td>
                  <td class="text-end">{{ p.counts.edges|number_format }}</td>

                  <td style="min-width: 18rem;">
                    {% if p.longest %}
                      <ul class="list-unstyled mb-0">
                        {% for w in p.longest %}
                        <li class="text-truncate">
                          <a class="link-primary"
                             href="{{ p.translate_url ~ '&q=' ~ w|url_encode }}"
                             title="Translate '{{ w }}' ({{ p.src }}→{{ p.dst }})">
                            <code>{{ w }}</code>
                          </a>
                        </li>
                        {% endfor %}
                      </ul>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>

                  <td style="min-width: 18rem;">
                    {% if p.recent %}
                      <ul class="list-unstyled mb-0">
                        {% for w in p.recent %}
                        <li class="text-truncate">
                          <a class="link-secondary"
                             href="{{ p.translate_url ~ '&q=' ~ w|url_encode }}"
                             title="Translate '{{ w }}' ({{ p.src }}→{{ p.dst }})">
                            <code>{{ w }}</code>
                          </a>
                        </li>
                        {% endfor %}
                      </ul>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>

                  <td class="text-end">
                    <div class="btn-list">
                      <a href="{{ p.translate_url }}" class="btn btn-primary">
                        Translate {{ p.src }}→{{ p.dst }}
                      </a>
                      {% if p.longest|length > 0 %}
                      <a href="{{ p.translate_url ~ '&q=' ~ (p.longest|first)|url_encode }}"
                         class="btn btn-outline-primary">
                        Try “{{ (p.longest|first)|u.truncate(18, '…') }}”
                      </a>
                      {% endif %}
                    </div>
                  </td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
