{% extends 'base.html.twig' %}

{% block title %}Translator{% endblock %}

{% block body %}
<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Translate (FreeDict)</h3>
            <div class="card-actions">
              <a class="btn btn-outline-secondary" href="{{ path('status_dashboard') }}">Dashboard</a>
            </div>
          </div>
          <div class="card-body">
            <form action="{{ path('libre_ui') }}" method="get" class="row g-3">
              <div class="col-12 col-md-5">
                <label class="form-label">Source</label>
                <select class="form-select" name="source" id="source">
                  {% for code, name in languages %}
                    <option value="{{ code }}" {{ code == (prev_source ?? '') ? 'selected' : '' }}>
                      {{ name }} ({{ code }})
                    </option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-12 col-md-2 d-flex align-items-end justify-content-center">
                <button type="button" id="swapBtn" class="btn btn-outline-secondary mt-2" title="Swap languages">⟷</button>
              </div>
              <div class="col-12 col-md-5">
                <label class="form-label">Target</label>
                <select class="form-select" name="target" id="target">
                  {% for code, name in languages %}
                    <option value="{{ code }}" {{ code == (prev_target ?? '') ? 'selected' : '' }}>
                      {{ name }} ({{ code }})
                    </option>
                  {% endfor %}
                </select>
              </div>

              <div class="col-12">
                <label class="form-label">Text</label>
                <textarea class="form-control" name="q" rows="3" placeholder="Enter text to translate">{{ prev_q ?? '' }}</textarea>
              </div>

              <div class="col-12 d-flex align-items-center gap-3">
                <label class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="use_rules" value="1" {{ (prev_use_rules ?? 0) ? 'checked' : '' }}>
                  <span class="form-check-label">Use simple rules (en→es articles)</span>
                </label>

                <label class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="via_http" value="1" {{ (prev_via_http ?? 0) ? 'checked' : '' }}>
                  <span class="form-check-label">Call internal API (/translate)</span>
                </label>

                <button type="submit" class="btn btn-primary ms-auto">Translate</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      {% if translatedText is not empty or error is not empty %}
      <div class="col-12">
        <div class="card">
          <div class="card-header"><h3 class="card-title">Result</h3></div>
          <div class="card-body">
            {% if error %}
              <div class="alert alert-danger">{{ error }}</div>
            {% endif %}
            {% if translatedText %}
              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <label class="form-label">Source</label>
                  <div class="card card-sm"><div class="card-body"><div class="text-muted">{{ prev_q ?? '' }}</div></div></div>
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label">Translation</label>
                  <div class="card card-sm"><div class="card-body"><div>{{ translatedText }}</div></div></div>
                </div>
              </div>
            {% endif %}
          </div>
          <div class="card-footer d-flex">
            <a href="{{ path('status_dashboard') }}" class="btn btn-outline-secondary">Back to Dashboard</a>
          </div>
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
document.getElementById('swapBtn')?.addEventListener('click', function() {
  const s = document.getElementById('source');
  const t = document.getElementById('target');
  if (!s || !t) return;
  const sv = s.value; s.value = t.value; t.value = sv;
});
</script>
{% endblock %}
